{
  "expo": {
    "name": "Zwrotka",
    "slug": "zwrotka",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1117"
      },
      "package": "pl.zwrotka.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Zwrotka potrzebuje dostępu do aparatu, aby skanować kody voucherów."
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "zwrotka",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "pl.zwrotka.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "79a414d5-8d12-41fa-bb41-d5e1884309d9"
      }
    },
    "owner": "adix0n"
  }
}
